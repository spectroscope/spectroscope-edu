{
  // Cloudflare Workers Static Assets, pass-through worker (project standard).
  // Build command: npm run build → ./dist ; deploy: npx wrangler deploy (push = deploy).
  "name": "spectroscope-edu",
  "compatibility_date": "2026-07-01",
  "main": "src/worker.js",
  "workers_dev": true,
  "preview_urls": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
